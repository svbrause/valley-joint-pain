# Copy to `.env.local` and fill in values. `.env.local` is gitignored.
# In Vercel: Project → Settings → Environment Variables — add the same names.

# Airtable Personal Access Token (starts with pat...)
# https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# Base ID from https://airtable.com/api — starts with app...
AIRTABLE_BASE_ID=

# Table name (must match your base exactly; URL-encoded when calling API)
AIRTABLE_TABLE_NAME=GAE Leads

# Slack Incoming Webhook for #gae-pilot (create in Slack: workspace → Apps → Incoming Webhooks → pick channel #gae-pilot)
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_GAE_PILOT=
